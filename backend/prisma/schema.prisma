// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id @default(cuid())
  email       String      @unique
  name        String?
  created_at  DateTime    @default(now())
  itineraries Itinerary[]
  bookings    Booking[]

  @@map("users")
}

model Destination {
  id                String         @id @default(cuid())
  name              String         @unique
  region            String
  short_summary     String
  description       String
  best_time         String
  avg_cost_per_day  Int
  highlights        String[]
  travel_tips       String[]
  ideal_for         String[]
  cover_image_url   String
  gallery_image_urls String[]
  itinerary_days    ItineraryDay[]

  @@map("destinations")
}

model Itinerary {
  id             String         @id @default(cuid())
  user_id        String?
  days           Int
  budget         Int
  interests      String[]
  total_cost     Int
  hotel_cost     Int
  transport_cost Int
  food_cost      Int
  created_at     DateTime       @default(now())
  user           User?          @relation(fields: [user_id], references: [id])
  itinerary_days ItineraryDay[]
  custom_trip_registrations CustomTripRegistration[]

  @@map("itineraries")
}

model ItineraryDay {
  id             String      @id @default(cuid())
  itinerary_id   String
  day_number     Int
  destination_id String
  activities     String
  cost           Int
  itinerary      Itinerary   @relation(fields: [itinerary_id], references: [id])
  destination    Destination @relation(fields: [destination_id], references: [id])

  @@map("itinerary_days")
}

model TourPackage {
  id             String      @id @default(cuid())
  title          String
  slug           String      @unique
  region         String
  summary        String
  description    String
  stay_style     String
  difficulty_level String
  departure_notes String
  travel_date    DateTime
  duration_days  Int
  price_per_seat Int
  total_seats    Int
  available_seats Int
  pickup_city    String
  package_type   String
  destinations   String[]
  inclusions     String[]
  exclusions     String[]
  itinerary_overview String[]
  cover_image_url String
  gallery_image_urls String[]
  is_active      Boolean     @default(true)
  created_at     DateTime    @default(now())
  bookings       Booking[]

  @@map("packages")
}

model Booking {
  id               String        @id @default(cuid())
  package_id       String
  user_id          String?
  full_name        String
  email            String
  phone            String
  national_id      String
  seats            Int
  status           BookingStatus @default(PENDING)
  total_amount     Int
  special_requests String?
  created_at       DateTime      @default(now())
  package          TourPackage   @relation(fields: [package_id], references: [id])
  user             User?         @relation(fields: [user_id], references: [id])

  @@map("bookings")
}

model CustomTripRegistration {
  id               String        @id @default(cuid())
  itinerary_id     String?
  full_name        String
  email            String
  phone            String
  national_id      String
  seats            Int
  days             Int
  budget           Int
  interests        String[]
  trip_summary     String
  destinations     String[]
  estimated_total  Int
  status           BookingStatus @default(PENDING)
  special_requests String?
  created_at       DateTime      @default(now())
  itinerary        Itinerary?    @relation(fields: [itinerary_id], references: [id])

  @@map("custom_trip_registrations")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

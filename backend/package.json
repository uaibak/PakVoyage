{
  "name": "pakvoyage-backend",
  "version": "1.0.0",
  "description": "Backend for PakVoyage travel planner",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "tsx src/main.ts",
    "start:dev": "tsx watch src/main.ts",
    "start:debug": "node --inspect -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "start:prod": "node dist/main",
    "prisma:generate": "prisma generate",
    "db:seed": "ts-node prisma/seed.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node -e \"console.log('No automated tests configured yet.')\"",
    "test:watch": "node -e \"console.log('No automated tests configured yet.')\"",
    "test:cov": "node -e \"console.log('No automated tests configured yet.')\"",
    "test:debug": "node -e \"console.log('No automated tests configured yet.')\"",
    "test:e2e": "node -e \"console.log('No automated tests configured yet.')\""
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "prettier": "^3.0.0",
    "prisma": "^5.0.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.1.3"
  }
}
